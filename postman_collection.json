    {
      "name": "List Schools",
      "item": [
        {
          "name": "List Schools — Valid coordinates (New York)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/listSchools?latitude=40.7128&longitude=-74.0060",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "listSchools"
              ],
              "query": [
                {
                  "key": "latitude",
                  "value": "40.7128"
                },
                {
                  "key": "longitude",
                  "value": "-74.0060"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has success true', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.eql(true);",
                  "});",
                  "",
                  "pm.test('Response has count and data array', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('count');",
                  "    pm.expect(json.data).to.be.an('array');",
                  "    pm.expect(json.count).to.eql(json.data.length);",
                  "});",
                  "",
                  "pm.test('Each school has distance field', function () {",
                  "    const json = pm.response.json();",
                  "    json.data.forEach(function (school) {",
                  "        pm.expect(school).to.have.property('distance');",
                  "        pm.expect(school.distance).to.be.a('number');",
                  "    });",
                  "});",
                  "",
                  "pm.test('Schools are sorted by distance (ascending)', function () {",
                  "    const json = pm.response.json();",
                  "    for (let i = 1; i < json.data.length; i++) {",
