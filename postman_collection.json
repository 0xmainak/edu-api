        {
          "name": "Add School — Valid Data",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Springfield Elementary\",\n  \"address\": \"123 Main St, Springfield\",\n  \"latitude\": 39.7817,\n  \"longitude\": -89.6501\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/addSchool",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "addSchool"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has success true', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.eql(true);",
                  "});",
                  "",
                  "pm.test('Response contains school data with id', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('id');",
                  "    pm.expect(json.data.name).to.eql('Springfield Elementary');",
                  "    pm.expect(json.data.address).to.eql('123 Main St, Springfield');",
                  "    pm.expect(json.data.latitude).to.eql(39.7817);",
                  "    pm.expect(json.data.longitude).to.eql(-89.6501);",
                  "});",
                  "",
                  "// Save the school ID for later use",
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('schoolId', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
